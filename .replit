modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
EBAY_ENV = "sandbox"
EBAY_VERIFICATION_TOKEN = "029aaf19cf5ba6570d27fb9d6a365a3f048fbb77dc56fb16646c4dafc274d39a"
EBAY_NOTIFICATION_ENDPOINT_URL = "https://flipscan.replit.app/api/ebay/account-deletion"
